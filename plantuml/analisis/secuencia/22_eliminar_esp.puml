@startuml
!include ../../common.puml

actor P
boundary VCH
control CH
entity CESP32

P -> VCH : Presiona "Eliminar" en el ESP32
activate VCH
VCH -> P : mostrarConfirmaciónIrreversible()
P -> VCH : Confirma eliminación
VCH-> CH : solicitarEliminacionESP32()
activate CH
    CH -> CESP32 : eliminarESP32()
    activate CESP32
  
    CESP32 --> CH : eliminacion_exitosa
    deactivate CESP32

    CH --> VCH : confirmarExito()
    deactivate CH

    VCH -> VCH : refresh()


   
    VCH --> P : mostrarTablaESP32()
deactivate VCH  


@enduml