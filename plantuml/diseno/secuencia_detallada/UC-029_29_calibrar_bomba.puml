@startuml
autonumber

actor "Usuario" as A
actor "Temporizador" as E <<device>>
participant "CalibratePump (React)" as UI
participant "Aplicacion (Logica Cliente)" as APP
participant "Supabase JS Client" as SB
database "PostgreSQL" as DB

A -> UI: solicitarCalibracion()
activate UI
UI -> APP: validarEntradaYContexto()
activate APP
alt validacion incorrecta
  APP --> UI: errorValidacion
  UI --> A: mostrarError()
else validacion correcta
  APP -> SB: insert('calibrate') // crear tarea pendiente
  activate SB
  SB -> DB: INSERT calibrate (pending)
  activate DB
  DB --> SB: task_id
  deactivate DB
  SB --> APP: task_id
  deactivate SB

  E -> SB: rpc('get_pending_calibrations')
  activate SB
  SB -> DB: SELECT calibraciones pendientes
  activate DB
  DB --> SB: payload_calibracion
  deactivate DB
  SB --> E: parametros(GPIO, volumen_objetivo)
  deactivate SB

  E -> E: ejecutarBombeoCalibracion()
  E -> SB: rpc('complete_calibration')
  activate SB
  SB -> DB: UPDATE calibrate status=done
  activate DB
  DB --> SB: ok + volumen_medido_dispositivo
  deactivate DB
  SB --> E: ack
  deactivate SB

  A -> UI: ingresarVolumenMedidoFinal()
  UI -> APP: guardarCalibracionFinal()
  APP -> SB: insert('calibration')
  activate SB
  SB -> DB: INSERT calibration (resultado final)
  activate DB
  DB --> SB: ok
  deactivate DB
  SB --> APP: respuestaOK
  deactivate SB

  APP --> UI: respuestaOK
  UI --> A: mostrarConfirmacion()
end
deactivate APP
deactivate UI
@enduml
