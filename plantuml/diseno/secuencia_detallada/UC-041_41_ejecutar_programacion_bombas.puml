@startuml
autonumber

actor "ESP32" as E <<device>>
participant "Firmware ESP32 (Arduino)" as FW
participant "Cliente HTTP/MQTT" as NET
participant "Supabase API/RPC" as SB
database "PostgreSQL" as DB

E -> FW: loop()
activate FW
FW -> NET: solicitarProgramacionesPendientes()
activate NET
NET -> SB: rpc('get_pending_programs')
activate SB
SB -> DB: SELECT programaciones bombas pendientes
activate DB
DB --> SB: lista_programas
deactivate DB
SB --> NET: payload_programas
deactivate SB
NET --> FW: payload_programas
deactivate NET

FW -> FW: ejecutarGPIOBombas(segun_horario)
FW -> NET: reportarEjecucion()
activate NET
NET -> SB: rpc('register_execution')
activate SB
SB -> DB: INSERT/UPDATE historial ejecucion bombas
activate DB
DB --> SB: ok
deactivate DB
SB --> NET: ack
deactivate SB
NET --> FW: ack
deactivate NET
deactivate FW
@enduml
