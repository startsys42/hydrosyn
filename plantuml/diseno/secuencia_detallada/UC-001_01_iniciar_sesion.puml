@startuml
autonumber

actor "Usuario No Logueado" as A
participant "Login (React)" as UI
participant "Aplicacion (Logica Cliente)" as APP
participant "Supabase JS Client" as SB
database "PostgreSQL" as DB

A -> UI: iniciarCasoUso()
activate UI
UI -> APP: validarEntradaYContexto()
activate APP
alt validacion incorrecta
  APP --> UI: errorValidacion
  UI --> A: mostrarError()
else validacion correcta
  APP -> SB: auth.signInWithPassword()
  activate SB
  SB -> DB: query/rpc
  activate DB
  DB --> SB: datos/estado
  deactivate DB
  SB --> APP: respuesta
  deactivate SB
  APP -> SB: auth.getUser()
  activate SB
  SB -> DB: query/rpc
  activate DB
  DB --> SB: datos/estado
  deactivate DB
  SB --> APP: respuesta
  deactivate SB
  APP -> SB: auth.signOut()
  activate SB
  SB -> DB: query/rpc
  activate DB
  DB --> SB: datos/estado
  deactivate DB
  SB --> APP: respuesta
  deactivate SB
  APP -> SB: insert('login_attempts')
  activate SB
  SB -> DB: query/rpc
  activate DB
  DB --> SB: datos/estado
  deactivate DB
  SB --> APP: respuesta
  deactivate SB
  APP -> SB: select('admin_users')
  activate SB
  SB -> DB: query/rpc
  activate DB
  DB --> SB: datos/estado
  deactivate DB
  SB --> APP: respuesta
  deactivate SB
  APP -> SB: select('systems_users')
  activate SB
  SB -> DB: query/rpc
  activate DB
  DB --> SB: datos/estado
  deactivate DB
  SB --> APP: respuesta
  deactivate SB
  APP -> SB: select('roles')
  activate SB
  SB -> DB: query/rpc
  activate DB
  DB --> SB: datos/estado
  deactivate DB
  SB --> APP: respuesta
  deactivate SB
  APP --> UI: respuestaOK
  UI --> A: mostrarConfirmacion()
end
deactivate APP
deactivate UI
@enduml
